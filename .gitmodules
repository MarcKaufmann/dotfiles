[submodule "autoload/pathogen.vim"]
	path = autoload/pathogen.vim
	url = https://github.com/tpope/vim-pathogen.git
	ignore = dirty
[submodule "bundle/vim-pandoc"]
	path = bundle/vim-pandoc
	url = https://github.com/vim-pandoc/vim-pandoc.git
	ignore = dirty
[submodule "bundle/vim-pandoc-syntax"]
	path = bundle/vim-pandoc-syntax
	url = https://github.com/vim-pandoc/vim-pandoc-syntax.git
	ignore = dirty
[submodule "bundle/vim-snippets"]
	path = UltiSnips/vim-snippets
	url = https://github.com/honza/vim-snippets.git
[submodule "bundle/julia-vim"]
	path = bundle/julia-vim
	url = https://github.com/JuliaLang/julia-vim.git
[submodule "bundle/vim-racket"]
	path = bundle/vim-racket
	url = https://github.com/wlangstroth/vim-racket.git
